# Nothing sensitive should ever land in this repo.
*.bak
*.log
.DS_Store

# Runtime state written into the clone at install time (never commit).
/.apt-installed
/.docker-group-added
/.docker-ipv6
/.config
/.dl-base
/.dl-image
/.claude/
/.memory/
/gh/

# Safety net: never commit credentials / secrets.
.credentials.json
*.pem
*.key
.env
